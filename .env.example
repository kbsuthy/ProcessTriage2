# Flask
APP_ENV=development
FLASK_SECRET_KEY=replace-with-a-long-random-secret
FLASK_DEBUG=0
PORT=5000
SESSION_COOKIE_SECURE=0

# Database
DATABASE_URL=sqlite:///project.db

# Admin access
# Option 1: Explicit allow-list of existing user emails
ADMIN_EMAILS=admin@example.com

# Option 2: Bootstrap an admin account at startup
# (If using these, password must meet policy: min 10 chars, upper/lower/number)
ADMIN_LOGIN_EMAIL=admin@example.com
ADMIN_LOGIN_PASSWORD=ChangeMe12345

# Password reset email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=mailer@example.com
SHOW_RESET_CODE=0

# AI features (optional)
# Preferred: Mistral AI
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Alternative: OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
